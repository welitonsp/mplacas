MPLACAS_ENVIRONMENT=development
MPLACAS_LOG_LEVEL=INFO
MPLACAS_GCP_PROJECT_ID=
MPLACAS_CLOUD_TRACE_ENABLED=false
MPLACAS_TRACE_SAMPLE_RATE=0.1
MPLACAS_CLOUD_METRICS_ENABLED=false
MPLACAS_METRICS_EXPORT_INTERVAL_SECONDS=60
MPLACAS_TIMEZONE=America/Sao_Paulo
# Local development (SQLite):
MPLACAS_DATABASE_URL=sqlite+aiosqlite:///./mplacas.db
# Neon PostgreSQL runtime: use the pooled hostname containing "-pooler".
# MPLACAS_DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# postgres:// and postgresql:// are normalized to postgresql+asyncpg://.
# sslmode and channel_binding are removed from the URL and SSL is supplied to asyncpg.
PORT=8080
MPLACAS_READINESS_TIMEOUT_SECONDS=3
MPLACAS_NEP_BASE_URL=https://api.nepviewer.net/v2
MPLACAS_NEP_ACCOUNT=
MPLACAS_NEP_PASSWORD=
MPLACAS_CLIMATE_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com/v1/archive
MPLACAS_EXTERNAL_HTTP_ALLOWED_HOSTS=api.nepviewer.net,archive-api.open-meteo.com
MPLACAS_CLIMATE_MAXIMUM_BACKFILL_DAYS=366
MPLACAS_PIPELINE_STALE_LOCK_TIMEOUT_MINUTES=60
MPLACAS_OUTBOX_STALE_LOCK_TIMEOUT_MINUTES=15
MPLACAS_OUTBOX_DISPATCH_BATCH_SIZE=100
MPLACAS_OUTBOX_MAX_ATTEMPTS=10
MPLACAS_EXPLANATION_API_URL=
MPLACAS_EXPLANATION_API_KEY=
MPLACAS_EXPLANATION_MODEL=
MPLACAS_EXPLANATION_TIMEOUT_SECONDS=15
MPLACAS_OPERATIONS_API_KEY=
MPLACAS_OPERATIONS_READ_API_KEY=
# MPLACAS_OPERATIONS_READ_PLANT_IDS=00000000-0000-0000-0000-000000000001
MPLACAS_TELEGRAM_BOT_TOKEN=
MPLACAS_TELEGRAM_WEBHOOK_SECRET=
MPLACAS_TELEGRAM_ALLOWED_USER_ID=
MPLACAS_TELEGRAM_ALERT_CHAT_ID=
MPLACAS_REQUEST_TIMEOUT_SECONDS=20
MPLACAS_CLOUD_JOB_PLANT_ID=
MPLACAS_CLOUD_JOB_EXPECTED_DAILY_PRODUCTION_KWH=
MPLACAS_CLOUD_JOB_EXPECTED_CYCLE_PRODUCTION_KWH=
MPLACAS_CLOUD_JOB_ANOMALY_DAYS=7
