# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
#
# These values are included in the browser bundle — they are NOT secrets.
# Authorization is enforced by the backend on every request.

# Backend API base URL (no trailing slash).
# In production, must use HTTPS.
VITE_API_URL=https://your-backend-api.example.com

# UUID of the plant to display on the dashboard.
# This is a UI configuration value only — the backend validates credentials and scope.
VITE_PLANT_ID=00000000-0000-0000-0000-000000000000
