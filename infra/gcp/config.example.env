# Copy to infra/gcp/config.env in Google Cloud Shell.
# Never commit config.env or real secret values.
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_NAME=mplacas-api
GCP_MIGRATION_JOB_NAME=mplacas-migrate
GCP_RUNTIME_SERVICE_ACCOUNT=mplacas-runtime
GCP_MIN_INSTANCES=0
GCP_MAX_INSTANCES=1
GCP_CPU=1
GCP_MEMORY=512Mi
GCP_CONCURRENCY=20
GCP_REQUEST_TIMEOUT=60
MPLACAS_TIMEZONE=America/Sao_Paulo
# Database secrets — dois endpoints separados do Neon:
#
#   mplacas-database-url (pooled):
#     Usado pelo Cloud Run runtime. Hostname contém "-pooler".
#     Cadastrar com: bash infra/gcp/set-secrets.sh database-runtime
#
#   mplacas-migration-database-url (direto/não-pooled):
#     Usado pelo Cloud Run Job de migrações (alembic upgrade head).
#     DDL requer conexão direta — NÃO use o endpoint pooled aqui.
#     Cadastrar com: bash infra/gcp/set-secrets.sh database-migration
#
# Ambos os valores ficam no Secret Manager — nunca neste arquivo.
# Both postgres:// and postgresql:// prefixes are normalized automatically.
# Exact Cloudflare Pages URL for CORS — never use wildcard (*).
# Example: https://mplacas-frontend.pages.dev
MPLACAS_CORS_ALLOWED_ORIGINS=
